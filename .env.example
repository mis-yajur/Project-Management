# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APPS_SCRIPT_URL: The public web app URL of your Google Apps Script deployment (optional).
# If provided, the webapp will use your Google Sheet as the live database.
# If omitted, it will automatically fall back to a robust local JSON database.
APPS_SCRIPT_URL="https://script.google.com/macros/s/.../exec"

# WhatsApp Notification Credentials from BhashSMS (optional overrides)
WA_USER="YajurFibre_BWAI"
WA_PASS="123456"
WA_SENDER="BUZWAP"

